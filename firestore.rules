rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────
    // ヘルパー関数
    // ─────────────────────────────────────────────

    function isLoggedIn() {
      return request.auth != null;
    }

    // users コレクションから現在ユーザーのロールを取得
    function myRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isLoggedIn() && myRole() == 'admin';
    }

    // admin または supporter
    function isAdminOrSupporter() {
      return isLoggedIn() && myRole() in ['admin', 'supporter'];
    }

    // pending 以外のログイン済みユーザー（通常メンバー以上）
    function isMember() {
      return isLoggedIn() && myRole() in ['admin', 'supporter', 'member'];
    }

    // ─────────────────────────────────────────────
    // users コレクション（ロール管理）
    // ─────────────────────────────────────────────
    match /users/{uid} {
      // 自分のドキュメントは常に読める（ロール確認のため）
      allow read: if isLoggedIn() && request.auth.uid == uid;
      // admin は全ユーザーを読める（UserApprovalPanel 用）
      allow read: if isAdmin();

      // 新規ユーザーは自分のドキュメントを作成できる（createPendingUser）
      allow create: if isLoggedIn() && request.auth.uid == uid;
      // ロール変更は admin のみ
      allow update: if isAdmin();
    }

    // ─────────────────────────────────────────────
    // members コレクション（名簿・プロフィール）
    // ─────────────────────────────────────────────
    match /members/{memberId} {
      // メンバー以上は全員読める（名簿閲覧）
      allow read: if isMember();

      // 自分自身のドキュメント（uid または email が一致）は編集できる
      // uid 未設定（初回ログイン）のメンバーも email 一致で編集できるようにする
      // ただし会員種別(membershipType=料金区分)とその変更履歴(membershipHistory)は本人では変更不可。
      // 種別の変更は下の isAdminOrSupporter() 経由（管理者・サポーター）のみ許可する。
      allow update: if isMember()
        && (resource.data.uid == request.auth.uid
          || resource.data.email == request.auth.token.email)
        && request.resource.data.get('membershipType', '') == resource.data.get('membershipType', '')
        && request.resource.data.get('membershipHistory', []) == resource.data.get('membershipHistory', []);

      // 新規作成: uid を自分の uid にする場合のみ許可
      allow create: if isMember()
        && request.resource.data.uid == request.auth.uid;

      // admin または supporter は任意のメンバードキュメントを作成・編集できる（代理編集）
      allow create, update: if isAdminOrSupporter();

      // 名簿からの削除（退会処理）は管理者(admin)のみ
      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────────
    // events コレクション（カレンダー・練習情報）
    // ─────────────────────────────────────────────
    match /events/{eventId} {
      // 練習スケジュールは非ログインでも閲覧可（ビジター向け表示のため）
      allow read: if true;
      // メンバーは予定の追加・編集・削除ができる（カレンダー入力・運用に必要）
      allow create: if isMember();
      allow update: if isMember();
      allow delete: if isMember();

      // reservations サブコレクション
      match /reservations/{reservationId} {
        allow read: if true;
        // メンバーは予約作成・自分の予約のキャンセルができる
        allow create: if isMember();
        allow update: if isMember();
        allow delete: if isAdmin();
      }

      // attendances サブコレクション（出欠回答）
      match /attendances/{attendanceId} {
        allow read: if isMember();
        // メンバーは自由に読み書きできる
        allow write: if isMember();
        // 未ログインのビジターは「参加表明」だけ新規作成できる（ログイン不要の見学・体験参加のため）。
        // 悪用を防ぐため、ドキュメントIDが visitor- で始まり、status が attend で、
        // 名前が [V] で始まる新規作成に限定する（既存レコードの書き換え・削除は不可）。
        allow create: if attendanceId.matches('visitor-.*')
          && request.resource.data.status == 'attend'
          && request.resource.data.name is string
          && request.resource.data.name.matches('\\[V\\].*');
      }

      // financials サブコレクション（当日会計のコーチ料上書きなど）
      match /financials/{docId} {
        allow read: if isMember();
        allow write: if isMember();
      }

      // visitors サブコレクション（ビジター登録）
      match /visitors/{visitorId} {
        allow read: if isMember();
        allow write: if isMember();
      }
    }

    // ─────────────────────────────────────────────
    // settings コレクション（当番・車代など）
    // ─────────────────────────────────────────────
    match /settings/{docId} {
      allow read: if isMember();
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────
    // 乗り合わせ表（全メンバー編集可能）
    // ─────────────────────────────────────────────
    match /transport/{docId} {
      allow read: if isMember();
      allow write: if isMember();
    }

    // ─────────────────────────────────────────────
    // 車代精算基準表（管理者・サポーター編集可）
    // ─────────────────────────────────────────────
    match /carFeeAreas/{docId} {
      allow read: if isMember();
      allow write: if isAdminOrSupporter();
    }

    // ─────────────────────────────────────────────
    // 施設カード関連
    // ─────────────────────────────────────────────
    match /facility_cards/{docId} {
      allow read: if isMember();
      allow write: if isMember(); // 現在は全メンバー編集可（将来 isAdmin() に変更可）
    }

    match /hamaspo_cards/{docId} {
      allow read: if isMember();
      allow write: if isMember();
    }

    match /facility_backups/{docId} {
      allow read: if isMember();
      allow write: if isAdmin();
    }

    // ─────────────────────────────────────────────
    // お知らせ・コミュニケーション
    // ─────────────────────────────────────────────
    match /announcements/{docId} {
      allow read: if isMember();
      // メンバーはお知らせ・議事録などを投稿できる
      allow create: if isMember();
      // 編集・削除は「投稿者本人」または「管理者・サポーター」だけ。
      // 他人の投稿を誤って消したり書き換えたりできないようにする。
      // 過去の投稿（authorUid 無し）は管理者・サポーターのみ操作可。
      allow update: if isAdminOrSupporter()
        || (isMember() && resource.data.get('authorUid', '') == request.auth.uid);
      allow delete: if isAdminOrSupporter()
        || (isMember() && resource.data.get('authorUid', '') == request.auth.uid);
    }

    match /suggestions/{suggestionId} {
      allow read: if isMember();
      allow create: if isMember();
      allow update: if isMember();
      allow delete: if isAdmin();

      // 返信サブコレクション
      match /replies/{replyId} {
        allow read: if isMember();
        allow create: if isMember();
        allow delete: if isAdmin();
      }
    }

    // 通知（ユーザーごとのサブコレクション・個人向け：意見箱への返信／タスクの担当割り当てなど）
    match /users/{uid}/notifications/{notifId} {
      // 読む・既読にする・消すは本人だけ（プライバシー保護）
      allow read, update, delete: if isLoggedIn() && request.auth.uid == uid;
      // 作成はメンバーなら可（他メンバーへ「返信あり」「担当になりました」を届けるため）
      allow create: if isMember();
    }

    // 全員向け通知（ブロードキャスト：予定・アンケート・お知らせの追加）
    match /broadcasts/{docId} {
      // メンバーは全員読める
      allow read: if isMember();
      // メンバーは作成できる（予定・アンケート・お知らせの追加時にアプリが発行）
      allow create: if isMember();
      // 一度出した通知の書き換えは禁止。削除は管理者のみ。
      allow update: if false;
      allow delete: if isAdmin();
    }

    // 全員向け通知の「最終既読時刻」（本人のみ読み書き）
    match /notificationState/{uid} {
      allow read, write: if isLoggedIn() && request.auth.uid == uid;
    }

    // ─────────────────────────────────────────────
    // 財務・記録
    // ─────────────────────────────────────────────
    match /transactions/{docId} {
      allow read: if isMember();

      // 作成: メンバー可。ただし金額・種別・日付の形式を必須にして異常データの混入を防ぐ。
      // （参加費は予約確定時に自動で家計簿へ記録されるため、作成自体はメンバーに開放する必要がある）
      allow create: if isMember()
        && request.resource.data.amount is number
        && request.resource.data.type in ['income', 'expense', 'transfer']
        && request.resource.data.date is string;

      // 更新（上書き）は全面禁止: 確定済みの記録を後から書き換えられないようにする（改ざん防止）。
      // アプリ側も transactions の更新は行わず「追加」と「削除」のみで運用している。
      allow update: if false;

      // 削除: メンバー可（予約キャンセルや精算のやり直しで必要）。
      allow delete: if isMember();
    }

    match /paymentCollections/{docId} {
      allow read: if isMember();
      // 集金（誰がいくら納入したか）の記録は管理者・サポーターが編集できる
      allow write: if isAdminOrSupporter();
    }

    match /eventExpenses/{docId} {
      allow read: if isMember();
      allow write: if isMember();
    }

    // 集金催促の承認待ちデータ（幹事が申請→管理者が承認/却下したら削除）
    match /reminderRequests/{id} {
      allow read, write: if isLoggedIn();
    }

    // ─────────────────────────────────────────────
    // 申請管理
    // ─────────────────────────────────────────────
    match /applications/{appId} {
      // メンバー以上は全件読める（一覧表示・署名確認）
      allow read: if isMember();
      // メンバーは申請を作成できる
      allow create: if isMember()
        // ビジター（未ログイン）も「新規入会申請」だけは送信できる。
        // 種別=join・状態=pending・署名ゼロに限定し、悪用を防ぐ。
        || (
          request.resource.data.type == 'join'
          && request.resource.data.status == 'pending'
          && request.resource.data.signatures.size() == 0
          && request.resource.data.requiredSignatures == 0
          && request.resource.data.applicantName is string
          && request.resource.data.applicantName.size() > 0
          && request.resource.data.applicantName.size() <= 50
          && request.resource.data.email is string
          && request.resource.data.email.size() > 0
          && request.resource.data.email.size() <= 200
        );
      // 署名追加・ステータス変更: メンバー（自分の署名追加）または admin
      allow update: if isMember();
      allow delete: if isAdmin();
    }

    // ─────────────────────────────────────────────
    // タスク・アンケート・あみだくじ・アルバム・備品
    // ─────────────────────────────────────────────
    match /tasks/{docId} {
      allow read: if isMember();
      allow write: if isMember();
    }

    match /surveys/{surveyId} {
      allow read: if isMember();
      // アンケートの作成は全メンバー可
      allow create: if isMember();
      // 投票（票数・投票者・連絡事項の項目だけの更新）は全メンバー可。
      // タイトル等の編集や「終了」は作成者本人か管理者・サポーターのみ。
      allow update: if isMember() && (
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['votesByOption', 'voterMap', 'commentMap', 'nameMap'])
        || isAdminOrSupporter()
        || resource.data.get('createdByUid', '') == request.auth.uid
      );
      // 削除は作成者本人か管理者・サポーターのみ
      allow delete: if isAdminOrSupporter()
        || (isMember() && resource.data.get('createdByUid', '') == request.auth.uid);
    }

    // あみだくじ（幹事決めなどの抽選）
    match /lotteries/{docId} {
      allow read: if isMember();
      // 作成は全メンバー可。引く（slots更新）・結果確定もメンバー全員が行えるようにする
      allow create: if isMember();
      allow update: if isMember();
      // 削除は作成者本人か管理者・サポーターのみ
      allow delete: if isAdminOrSupporter()
        || (isMember() && resource.data.get('createdByUid', '') == request.auth.uid);
    }

    match /albums/{docId} {
      allow read: if isMember();
      allow write: if isMember();
    }

    match /inventory/{docId} {
      allow read: if isMember();
      allow write: if isMember();
    }

    match /disposals/{docId} {
      allow read: if isMember();
      allow write: if isMember();
    }
  }
}
